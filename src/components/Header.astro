---
const navLinks = [
  { href: "/", label: "Home page" },
  { href: "/universe", label: "The universe" },
  { href: "/about", label: "Information" },
];
const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 inset-x-0 z-50 bg-[#E52521] text-white shadow-md fade-in-up" aria-label="Primary">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
    <div class="flex w-full items-center justify-between md:w-auto md:justify-start md:gap-4">
      <a href="/" class="flex items-center gap-3 interactive-lift">
        <img src="/favicon.svg" alt="Mario logo" class="h-10 w-10 object-contain pop-in" />
        <span class="hidden text-sm font-bold tracking-wide leading-tight md:block" style="font-family: 'Press Start 2P', monospace;">
          The Great Mushroom<br />Kingdom Wiki
        </span>
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="md:hidden inline-flex h-12 w-12 items-center justify-center rounded-md hover:cursor-pointer hover:bg-white/10 transition-colors"
        aria-expanded="false"
        aria-controls="primary-menu"
        aria-label="Toggle navigation menu"
      >
        <span class="sr-only">Open menu</span>
        <svg
          id="menu-open-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="h-7 w-7"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="menu-close-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-7 w-7"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>

    <ul
      id="primary-menu"
      class="hidden w-full mt-2 pt-3 border-t border-white/25 space-y-3 md:space-y-0 md:mt-0 md:pt-0 md:border-0 md:w-auto md:flex md:flex-wrap md:justify-end md:gap-4 lg:gap-6 text-sm font-semibold"
    >
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`interactive-link hover:underline underline-offset-4 transition-opacity ${currentPath === link.href ? "underline" : "opacity-90 hover:opacity-100"}`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script is:inline>
  const menuToggleButton = document.getElementById("menu-toggle");
  const primaryMenu = document.getElementById("primary-menu");
  const menuOpenIcon = document.getElementById("menu-open-icon");
  const menuCloseIcon = document.getElementById("menu-close-icon");

  const updateMenuToggleIcon = (isExpanded) => {
    menuOpenIcon?.classList.toggle("hidden", isExpanded);
    menuCloseIcon?.classList.toggle("hidden", !isExpanded);
  };

  menuToggleButton?.addEventListener("click", () => {
    const isExpanded = menuToggleButton.getAttribute("aria-expanded") === "true";
    const nextExpandedState = !isExpanded;
    menuToggleButton.setAttribute("aria-expanded", String(nextExpandedState));
    primaryMenu?.classList.toggle("hidden");
    updateMenuToggleIcon(nextExpandedState);
  });

  primaryMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 768) {
        primaryMenu.classList.add("hidden");
        menuToggleButton?.setAttribute("aria-expanded", "false");
        updateMenuToggleIcon(false);
      }
    });
  });

  updateMenuToggleIcon(false);
</script>
