---
const navLinks = [
  { href: "/", label: "Home page" },
  { href: "/universe", label: "The universe" },
  { href: "/about", label: "Information" },
];
const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 inset-x-0 z-50 bg-[#E52521] text-white shadow-md fade-in-up" aria-label="Primary">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
    <a href="/" class="flex items-center gap-3 interactive-lift">
      <img src="/favicon.png" alt="Mario logo" class="h-10 w-10 object-contain pop-in" />
      <span class="text-sm font-bold tracking-wide leading-tight" style="font-family: 'Press Start 2P', monospace;">
        The Great Mushroom<br />Kingdom Wiki
      </span>
    </a>
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden inline-flex items-center justify-center gap-2 hover:cursor-pointer hover:bg-white/10 transition-colors"
      aria-expanded="false"
      aria-controls="primary-menu"
      aria-label="Toggle navigation menu"
    >
      <span class="sr-only">Open menu</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <ul
      id="primary-menu"
      class="hidden w-full mt-2 pt-3 border-t border-white/25 space-y-3 md:space-y-0 md:mt-0 md:pt-0 md:border-0 md:w-auto md:flex md:flex-wrap md:justify-end md:gap-4 lg:gap-6 text-sm font-semibold"
    >
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`interactive-link hover:underline underline-offset-4 transition-opacity ${currentPath === link.href ? "underline" : "opacity-90 hover:opacity-100"}`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script is:inline>
  const menuToggleButton = document.getElementById("menu-toggle");
  const primaryMenu = document.getElementById("primary-menu");

  menuToggleButton?.addEventListener("click", () => {
    const isExpanded = menuToggleButton.getAttribute("aria-expanded") === "true";
    menuToggleButton.setAttribute("aria-expanded", String(!isExpanded));
    primaryMenu?.classList.toggle("hidden");
  });

  primaryMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 768) {
        primaryMenu.classList.add("hidden");
        menuToggleButton?.setAttribute("aria-expanded", "false");
      }
    });
  });
</script>
